# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Google Sheets Configuration
# 1. Create a Google Sheet and copy its ID from the URL.
# 2. Create a Service Account in Google Cloud Console and download the JSON key.
# 3. Share your Google Sheet with the Service Account email.
GOOGLE_SHEET_ID="1CweJO5GUFtAP9jv5su5RVzMR2cMqHjxrnaugXhdjViM"
GOOGLE_SERVICE_ACCOUNT_EMAIL="YOUR_SERVICE_ACCOUNT_EMAIL"
GOOGLE_PRIVATE_KEY="YOUR_PRIVATE_KEY_HERE"

# LINE Messaging API Configuration
# 1. Create a Channel in LINE Developers Console.
# 2. Get Channel Secret and Channel Access Token.
# 3. Invite the bot to your family group and get the Group ID.
LINE_CHANNEL_ACCESS_TOKEN="YOUR_CHANNEL_ACCESS_TOKEN"
LINE_CHANNEL_SECRET="YOUR_CHANNEL_SECRET"
LINE_GROUP_ID="YOUR_GROUP_ID_HERE"

# Firebase Configuration
# 1. Go to Firebase Console -> Project Settings -> Service Accounts.
# 2. Click "Generate new private key".
# 3. Paste the entire JSON content into this variable.
FIREBASE_SERVICE_ACCOUNT_KEY=
